# Plugin manager
declare -A ZINIT
ZINIT[NO_ALIASES]=1 # Disable aliases

# Environment
export XDG_CONFIG_HOME=~/.config # TODO: Check if this is required for Linux otherwise add a guard to set only for MacOS
export GOPATH=~/.go # Global Go directory

# Path
declare -U path # De-duplicate path elements
# Custom scripts
local_bin=~/.bin
[[ -d "$local_bin" ]] && path+="$local_bin"
unset local_bin
# Doomemacs binaries
doomemacs_bin=~/.config/doomemacs/bin
[[ -d "$doomemacs_bin" ]] && path+="$doomemacs_bin"
unset doomemacs_bin

# UI/UX
HISTFILE=~/.zsh_history # File where history is stored
HISTSIZE=5000           # Number of entries to load from history file into shell memory
SAVEHIST=100000         # Number of entries stored in history file
